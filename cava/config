## Clean, working CAVA configuration
## Regenerated for proper gradient support
[general]
framerate = 60
autosens = 1
sensitivity = 100
bars = 0
bar_width = 2
bar_spacing = 1
center_align = 1
max_height = 100
lower_cutoff_freq = 50
higher_cutoff_freq = 10000
sleep_timer = 0
[input]
method = pulse
source = auto
sample_rate = 44100
sample_bits = 16
channels = 2
[output]
method = noncurses
orientation = bottom
channels = stereo
reverse = 0
synchronized_sync = 1
waveform = 0
[color]
# Enable vertical gradient
gradient = 1
gradient_color_1 = "#A8B8CC"
gradient_color_2 = "#0047AB"
gradient_color_3 = "#FFFFFF"
background = '#00052E'
[smoothing]
noise_reduction = 77
[eq]
# Flat EQ (default)
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1
